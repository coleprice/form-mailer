{
  "name": "@coleprice/emdash-plugin-form-mailer",
  "version": "0.1.1",
  "description": "Opinionated EmDash plugin for reliable form submission handling and email notifications.",
  "type": "module",
  "license": "MIT",
  "author": "Cole Price",
  "homepage": "https://coleprice.com/plugins/form-mailer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coleprice/form-mailer.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./sandbox": {
      "import": "./dist/sandbox-entry.mjs",
      "types": "./dist/sandbox-entry.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test"
  },
  "peerDependencies": {
    "emdash": "^0.5.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "emdash": "^0.5.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
